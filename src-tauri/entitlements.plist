<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow JIT compilation for better performance -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    
    <!-- Allow unsigned executable memory -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    
    <!-- Disable library validation to allow dynamic libraries -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    
    <!-- Allow DYLD environment variables -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    
    <!-- Network access (if needed for API calls) -->
    <key>com.apple.security.network.client</key>
    <true/>
    
    <key>com.apple.security.network.server</key>
    <true/>
    
    <!-- Audio input (if needed) -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    
    <!-- Camera (if needed) -->
    <key>com.apple.security.device.camera</key>
    <true/>
    
    <!-- Automation and scripting -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!-- Screen recording (required for window capture) -->
    <key>com.apple.security.screen-capture</key>
    <true/>
</dict>
</plist>


