{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rae",
  "version": "0.1.3",
  "identifier": "com.rae.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "rae",
        "width": 1000,
        "height": 600,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "alwaysOnTop": true,
        "decorations": false,
        "shadow": false,
        "maximizable": false,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default", "overlay-capability", "chat-capability"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": null
    }
  },

  "plugins": {
    "shell": {
      "open": true
    },
    "autostart": null,
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY2MDMzODdCMjlFMkI2QTIKUldTaXR1SXBlemdEOWlCOFcwdTZJUmw2OEhMUHZqaXJuUUdqeHpEcm8zMmdmK3JkeHIrbGxjdXEK",
      "endpoints": ["https://quackback-xwhd.onrender.com/updates/latest.json"]
    }
  }
}
